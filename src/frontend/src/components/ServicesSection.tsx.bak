type Subcategory = {
  name: string;
  description: string;
  benefits: string[];
};

type ServiceCategory = {
  id: string;
  title: string;
  color: string;
  gradient: string;
  glow: string;
  AnimComp: React.FC;
  subcategories: Subcategory[];
};

const SERVICES: ServiceCategory[] = [
  {
    id: "web-design",
