function WebDesignAnim() {
  return (
    <div className="relative w-full h-full flex items-center justify-center">
      <style>{`
        @keyframes wd-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
        @keyframes wd-bar1 { 0%{opacity:0;transform:scaleX(0)} 60%{opacity:1;transform:scaleX(1)} 100%{opacity:1;transform:scaleX(1)} }
        @keyframes wd-bar2 { 0%,20%{opacity:0;transform:scaleX(0)} 80%{opacity:1;transform:scaleX(1)} 100%{opacity:1;transform:scaleX(1)} }
        @keyframes wd-bar3 { 0%,40%{opacity:0;transform:scaleX(0)} 100%{opacity:1;transform:scaleX(1)} }
        @keyframes wd-fade1 { 0%{opacity:0} 40%{opacity:1} 100%{opacity:1} }
        @keyframes wd-fade2 { 0%,25%{opacity:0} 65%{opacity:1} 100%{opacity:1} }
        @keyframes wd-fade3 { 0%,50%{opacity:0} 90%{opacity:1} 100%{opacity:1} }
        @keyframes wd-cursor { 0%,100%{opacity:1} 50%{opacity:0} }
        @keyframes wd-scan { 0%{top:10%} 100%{top:90%} }
      `}</style>
      {/* Browser frame */}
      <div
        className="relative rounded-xl overflow-hidden shadow-2xl"
        style={{
          width: 260,
          height: 200,
          background: "#0d1117",
          border: "2px solid #00d4ff33",
          animation: "wd-float 4s ease-in-out infinite",
        }}
      >
        {/* Title bar */}
        <div
          className="flex items-center gap-1.5 px-3 py-2"
          style={{ background: "#161b22" }}
        >
          <div
            className="w-3 h-3 rounded-full"
            style={{ background: "#ff5f57" }}
          />
          <div
            className="w-3 h-3 rounded-full"
            style={{ background: "#febc2e" }}
          />
          <div
            className="w-3 h-3 rounded-full"
            style={{ background: "#28c840" }}
          />
          <div
            className="flex-1 mx-2 rounded-full h-4 px-2 flex items-center"
            style={{ background: "#21262d", fontSize: 8, color: "#8b949e" }}
          >
            https://yoursite.com
          </div>
        </div>
        {/* Content area */}
        <div className="p-3 space-y-2 relative overflow-hidden">
          {/* Hero banner */}
          <div
            className="rounded-md h-10"
            style={{
              background: "linear-gradient(90deg,#00d4ff33,#00d4ff55)",
              animation: "wd-fade1 1.2s ease forwards",
              opacity: 0,
              transformOrigin: "left",
            }}
          />
          {/* Nav bar */}
          <div
            className="flex gap-1"
            style={{ animation: "wd-fade2 1.8s ease forwards", opacity: 0 }}
          >
            {["Home", "About", "Services", "Contact"].map((n) => (
              <div
                key={n}
                className="rounded h-3 flex-1"
                style={{
                  background: "#00d4ff22",
                  fontSize: 6,
                  color: "#00d4ffaa",
                  display: "flex",
                  alignItems: "center",
                  justifyContent: "center",
                }}
              >
                {n}
              </div>
            ))}
          </div>
          {/* Cards */}
          <div
            className="grid grid-cols-3 gap-1"
            style={{ animation: "wd-fade3 2.4s ease forwards", opacity: 0 }}
          >
            {["#00d4ff", "#84cc16", "#a855f7"].map((c) => (
              <div
                key={c}
                className="rounded-md"
                style={{
                  height: 40,
                  background: `${c}22`,
                  border: `1px solid ${c}44`,
                }}
              />
            ))}
          </div>
          {/* Text lines */}
          <div
            className="space-y-1"
            style={{ animation: "wd-fade3 2.8s ease forwards", opacity: 0 }}
          >
            <div
              className="rounded-full h-1.5"
              style={{
                background: "#ffffff22",
                animation: "wd-bar1 2s ease forwards",
                transformOrigin: "left",
                opacity: 0,
              }}
            />
            <div
              className="rounded-full h-1.5 w-3/4"
              style={{
                background: "#ffffff15",
                animation: "wd-bar2 2.4s ease forwards",
                transformOrigin: "left",
                opacity: 0,
              }}
            />
          </div>
          {/* Scan line */}
          <div
            className="absolute left-0 right-0 h-px pointer-events-none"
            style={{
              background:
                "linear-gradient(90deg,transparent,#00d4ff88,transparent)",
              animation: "wd-scan 2.5s linear infinite",
              top: "10%",
            }}
          />
        </div>
      </div>
      {/* Glow */}
      <div
        className="absolute inset-0 rounded-2xl pointer-events-none"
        style={{
          background:
            "radial-gradient(circle at 50% 50%,#00d4ff18,transparent 70%)",
        }}
      />
    </div>
  );
}

function WebDevAnim() {
  const lines = [
    { text: "const app = express();    ", color: "#c792ea" },
    { text: "app.use(cors());           ", color: "#82aaff" },
    { text: "app.get('/api', async()=> {", color: "#c3e88d" },
    { text: "  const data = await db    ", color: "#ffffff99" },
    { text: "    .query(sql`SELECT *    ", color: "#f78c6c" },
    { text: "    FROM users`);          ", color: "#f78c6c" },
    { text: "  res.json({ data });       ", color: "#c3e88d" },
    { text: "});                        ", color: "#c792ea" },
    { text: "app.listen(3000); ✓ Ready ", color: "#84cc16" },
  ];
  return (
    <div className="relative w-full h-full flex items-center justify-center">
      <style>{`
        @keyframes wdev-float { 0%,100%{transform:translateY(0) rotate(-1deg)} 50%{transform:translateY(-8px) rotate(1deg)} }
        @keyframes wdev-type { from{opacity:0;transform:translateX(-8px)} to{opacity:1;transform:translateX(0)} }
        @keyframes wdev-blink { 0%,100%{opacity:1} 50%{opacity:0} }
      `}</style>
      <div
        className="rounded-xl overflow-hidden shadow-2xl font-mono"
        style={{
          width: 280,
          height: 210,
          background: "#0d1117",
          border: "2px solid #84cc1633",
          animation: "wdev-float 5s ease-in-out infinite",
        }}
      >
        <div
          className="flex items-center gap-2 px-3 py-2"
          style={{ background: "#161b22" }}
        >
          <div
            className="w-3 h-3 rounded-full"
            style={{ background: "#ff5f57" }}
          />
          <div
            className="w-3 h-3 rounded-full"
            style={{ background: "#febc2e" }}
          />
          <div
            className="w-3 h-3 rounded-full"
            style={{ background: "#28c840" }}
          />
          <span style={{ fontSize: 9, color: "#8b949e", marginLeft: 4 }}>
            server.js — Node.js
          </span>
        </div>
        <div className="p-3" style={{ fontSize: 9, lineHeight: 1.9 }}>
          {lines.map((l, i) => (
            <div
              key={l.text}
              style={{
                color: l.color,
                animation: "wdev-type 0.3s ease forwards",
                animationDelay: `${0.3 + i * 0.25}s`,
                opacity: 0,
              }}
            >
              <span style={{ color: "#4a5568", marginRight: 6 }}>
                {String(i + 1).padStart(2, " ")}
              </span>
              {l.text}
              {i === lines.length - 1 && (
                <span
                  style={{
                    animation: "wdev-blink 1s step-end infinite",
                    color: "#84cc16",
                  }}
                >
                  █
                </span>
              )}
            </div>
          ))}
        </div>
      </div>
      <div
        className="absolute inset-0 rounded-2xl pointer-events-none"
        style={{
          background:
            "radial-gradient(circle at 50% 50%,#84cc1615,transparent 70%)",
        }}
      />
    </div>
  );
}

function MobileAppAnim() {
  return (
    <div className="relative w-full h-full flex items-center justify-center">
      <style>{`
        @keyframes mob-float { 0%,100%{transform:translateY(0) rotate(1deg)} 50%{transform:translateY(-10px) rotate(-1deg)} }
        @keyframes mob-icon { from{opacity:0;transform:scale(0)} to{opacity:1;transform:scale(1)} }
        @keyframes mob-bar { from{width:0} to{width:70%} }
        @keyframes mob-swipe { 0%{transform:translateX(0);opacity:1} 40%{transform:translateX(-30px);opacity:0} 41%{transform:translateX(30px);opacity:0} 80%{transform:translateX(0);opacity:1} 100%{transform:translateX(0);opacity:1} }
        @keyframes mob-status { 0%,100%{background:#a855f7} 50%{background:#ec4899} }
      `}</style>
      {/* Phone */}
      <div
        className="relative rounded-3xl overflow-hidden shadow-2xl"
        style={{
          width: 140,
          height: 240,
          background: "#0d1117",
          border: "3px solid #a855f744",
          animation: "mob-float 4.5s ease-in-out infinite",
        }}
      >
        {/* Notch */}
        <div
          className="absolute top-0 left-1/2 -translate-x-1/2 rounded-b-xl"
          style={{ width: 50, height: 14, background: "#0d1117", zIndex: 10 }}
        />
        {/* Status bar */}
        <div
          className="flex justify-between px-4 pt-3 pb-1"
          style={{ fontSize: 7, color: "#a855f799" }}
        >
          <span>9:41</span>
          <span>●●●</span>
        </div>
        {/* App icons grid */}
        <div className="px-3 pt-1 grid grid-cols-3 gap-2">
          {[
            "#00d4ff",
            "#84cc16",
            "#a855f7",
            "#f97316",
            "#ec4899",
            "#06b6d4",
            "#10b981",
            "#f59e0b",
            "#6366f1",
          ].map((c, i) => (
            <div
              key={c}
              className="rounded-xl flex items-center justify-center"
              style={{
                height: 32,
                background: `${c}33`,
                border: `1px solid ${c}66`,
                animation: "mob-icon 0.3s ease forwards",
                animationDelay: `${0.2 + i * 0.1}s`,
                opacity: 0,
              }}
            >
              <div
                className="w-3 h-3 rounded-sm"
                style={{ background: c, opacity: 0.8 }}
              />
            </div>
          ))}
        </div>
        {/* Progress bar */}
        <div
          className="mx-3 mt-3 h-1.5 rounded-full"
          style={{ background: "#ffffff11" }}
        >
          <div
            className="h-full rounded-full"
            style={{
              background: "linear-gradient(90deg,#a855f7,#ec4899)",
              animation: "mob-bar 2s ease-in-out infinite alternate",
            }}
          />
        </div>
        {/* Swipe screen */}
        <div
          className="mx-3 mt-2 rounded-xl p-2"
          style={{
            background: "#ffffff08",
            animation: "mob-swipe 3s ease-in-out infinite",
          }}
        >
          <div
            className="h-2 rounded-full w-2/3 mb-1.5"
            style={{ background: "#a855f744" }}
          />
          <div
            className="h-1.5 rounded-full w-full"
            style={{ background: "#ffffff15" }}
          />
          <div
            className="h-1.5 rounded-full w-4/5 mt-1"
            style={{ background: "#ffffff10" }}
          />
        </div>
        {/* Nav dots */}
        <div className="absolute bottom-3 left-0 right-0 flex justify-center gap-1.5">
          {[
            ["active", 1],
            ["dot1", 0],
            ["dot2", 0],
          ].map(([k, a], i) => (
            <div
              key={k}
              className="rounded-full"
              style={{
                width: a ? 12 : 5,
                height: 5,
                background: a ? "#a855f7" : "#ffffff33",
                animation: "mob-status 2s ease-in-out infinite",
                animationDelay: `${i * 0.5}s`,
              }}
            />
          ))}
        </div>
      </div>
      {/* Second phone shadow */}
      <div
        className="absolute rounded-3xl"
        style={{
          width: 130,
          height: 225,
          background: "#a855f708",
          border: "2px solid #a855f722",
          transform: "translateX(20px) translateY(15px) rotate(5deg)",
          zIndex: -1,
        }}
      />
      <div
        className="absolute inset-0 rounded-2xl pointer-events-none"
        style={{
          background:
            "radial-gradient(circle at 50% 50%,#a855f715,transparent 70%)",
        }}
      />
    </div>
  );
}

function GraphicDesignAnim() {
  return (
    <div className="relative w-full h-full flex items-center justify-center">
      <style>{`
        @keyframes gd-spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
        @keyframes gd-spin-rev { from{transform:rotate(0deg)} to{transform:rotate(-360deg)} }
        @keyframes gd-pulse { 0%,100%{transform:scale(1);opacity:0.8} 50%{transform:scale(1.15);opacity:1} }
        @keyframes gd-stroke { from{stroke-dashoffset:300} to{stroke-dashoffset:0} }
        @keyframes gd-morph { 0%,100%{border-radius:60% 40% 30% 70%/60% 30% 70% 40%} 50%{border-radius:30% 60% 70% 40%/50% 60% 30% 60%} }
        @keyframes gd-pen { 0%{transform:translate(0,0) rotate(-30deg)} 50%{transform:translate(80px,-20px) rotate(10deg)} 100%{transform:translate(160px,10px) rotate(-20deg)} }
      `}</style>
      {/* Main color wheel */}
      <div className="relative" style={{ width: 200, height: 200 }}>
        <div
          className="absolute inset-0 rounded-full"
          style={{
            background:
              "conic-gradient(#00d4ff,#84cc16,#a855f7,#ec4899,#f97316,#f59e0b,#00d4ff)",
            animation: "gd-spin 8s linear infinite",
            opacity: 0.9,
          }}
        />
        <div
          className="absolute inset-2 rounded-full"
          style={{
            background:
              "conic-gradient(#84cc16,#a855f7,#ec4899,#f97316,#00d4ff,#84cc16)",
            animation: "gd-spin-rev 5s linear infinite",
            opacity: 0.7,
          }}
        />
        <div
          className="absolute inset-6 rounded-full"
          style={{
            background:
              "conic-gradient(#ec4899,#f97316,#00d4ff,#84cc16,#a855f7,#ec4899)",
            animation: "gd-spin 3s linear infinite",
            opacity: 0.9,
          }}
        />
        {/* Center */}
        <div
          className="absolute inset-12 rounded-full flex items-center justify-center"
          style={{
            background: "#0d1117",
            animation: "gd-pulse 2s ease-in-out infinite",
          }}
        >
          <span style={{ fontSize: 22 }}>🎨</span>
        </div>
        {/* Morph blob */}
        <div
          className="absolute"
          style={{
            width: 50,
            height: 50,
            background: "#ec489966",
            top: -10,
            right: -10,
            animation: "gd-morph 4s ease-in-out infinite",
          }}
        />
        <div
          className="absolute"
          style={{
            width: 35,
            height: 35,
            background: "#84cc1666",
            bottom: 0,
            left: -5,
            animation: "gd-morph 3s ease-in-out infinite reverse",
          }}
        />
      </div>
      {/* Pen stroke SVG */}
      <svg
        aria-hidden="true"
        role="presentation"
        className="absolute"
        style={{
          top: "60%",
          left: 10,
          width: 180,
          height: 40,
          overflow: "visible",
        }}
      >
        <path
          d="M0,20 Q45,0 90,20 Q135,40 180,15"
          fill="none"
          stroke="url(#pgr)"
          strokeWidth="2.5"
          strokeLinecap="round"
          style={{
            strokeDasharray: 300,
            strokeDashoffset: 300,
            animation: "gd-stroke 2s ease forwards 0.5s",
          }}
        />
        <defs>
          <linearGradient id="pgr" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stopColor="#ec4899" />
            <stop offset="100%" stopColor="#f97316" />
          </linearGradient>
        </defs>
      </svg>
      <div
        className="absolute inset-0 rounded-2xl pointer-events-none"
        style={{
          background:
            "radial-gradient(circle at 50% 50%,#ec489915,transparent 70%)",
        }}
      />
    </div>
  );
}

function DigitalMarketingAnim() {
  const bars = [
    { h: 55, color: "#f97316", label: "SEO", delay: 0.1 },
    { h: 80, color: "#00d4ff", label: "PPC", delay: 0.25 },
    { h: 45, color: "#84cc16", label: "SMM", delay: 0.4 },
    { h: 90, color: "#a855f7", label: "Email", delay: 0.55 },
    { h: 65, color: "#ec4899", label: "CRM", delay: 0.7 },
  ];
  return (
    <div className="relative w-full h-full flex items-center justify-center">
      <style>{`
        @keyframes dm-rise { from{height:0;opacity:0} to{opacity:1} }
        @keyframes dm-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
        @keyframes dm-line { from{stroke-dashoffset:400} to{stroke-dashoffset:0} }
        @keyframes dm-badge { from{opacity:0;transform:scale(0) translateY(10px)} to{opacity:1;transform:scale(1) translateY(0)} }
        @keyframes dm-pulse-dot { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.5);opacity:0.6} }
      `}</style>
      <div
        style={{
          width: 280,
          height: 200,
          animation: "dm-float 4s ease-in-out infinite",
        }}
      >
        {/* Chart grid */}
        <div className="relative" style={{ height: 140 }}>
          {/* Y-axis lines */}
          {[0, 33, 66, 100].map((p) => (
            <div
              key={p}
              className="absolute left-0 right-0"
              style={{ bottom: `${p}%`, borderTop: "1px dashed #ffffff12" }}
            />
          ))}
          {/* Bars */}
          <div className="absolute bottom-0 left-0 right-0 flex items-end justify-around px-4">
            {bars.map((b) => (
              <div key={b.label} className="flex flex-col items-center gap-1">
                <div
                  className="rounded-t-md relative overflow-hidden"
                  style={{
                    width: 28,
                    height: b.h,
                    background: `linear-gradient(to top, ${b.color}cc, ${b.color}44)`,
                    border: `1px solid ${b.color}66`,
                    animation: "dm-rise 0.8s ease forwards",
                    animationDelay: `${b.delay}s`,
                    animationFillMode: "both",
                  }}
                >
                  {/* Shimmer */}
                  <div
                    className="absolute inset-0"
                    style={{
                      background: `linear-gradient(180deg,${b.color}44 0%,transparent 100%)`,
                    }}
                  />
                  {/* % badge */}
                  <div
                    className="absolute -top-5 left-1/2 -translate-x-1/2 rounded-full text-white font-bold whitespace-nowrap"
                    style={{
                      fontSize: 8,
                      padding: "1px 4px",
                      background: b.color,
                      animation: "dm-badge 0.4s ease forwards",
                      animationDelay: `${b.delay + 0.6}s`,
                      opacity: 0,
                    }}
                  >
                    +{b.h}%
                  </div>
                </div>
                <span style={{ fontSize: 8, color: b.color }}>{b.label}</span>
              </div>
            ))}
          </div>
          {/* Trend line */}
          <svg
            aria-hidden="true"
            role="presentation"
            className="absolute inset-0 w-full h-full"
            style={{ overflow: "visible" }}
            viewBox="0 0 280 140"
            preserveAspectRatio="none"
          >
            <path
              d="M30,120 L86,75 L142,105 L198,35 L254,65"
              fill="none"
              stroke="#f97316"
              strokeWidth="2"
              strokeDasharray="400"
              strokeDashoffset="400"
              strokeLinecap="round"
              style={{ animation: "dm-line 2s ease forwards 1s" }}
            />
            {[
              { x: 30, y: 120 },
              { x: 86, y: 75 },
              { x: 142, y: 105 },
              { x: 198, y: 35 },
              { x: 254, y: 65 },
            ].map((p, i) => (
              <circle
                key={p.x}
                cx={p.x}
                cy={p.y}
                r="4"
                fill="#f97316"
                style={{
                  animation: "dm-pulse-dot 1.5s ease-in-out infinite",
                  animationDelay: `${1 + i * 0.2}s`,
                }}
              />
            ))}
          </svg>
        </div>
        {/* X axis */}
        <div className="flex justify-around px-4 mt-1">
          {["Jan", "Mar", "May", "Aug", "Nov"].map((m) => (
            <span key={m} style={{ fontSize: 8, color: "#ffffff44" }}>
              {m}
            </span>
          ))}
        </div>
        {/* ROI label */}
        <div
          className="text-center mt-2"
          style={{ fontSize: 11, color: "#f97316", fontWeight: 700 }}
        >
          📈 Avg. 340% ROI
        </div>
      </div>
      <div
        className="absolute inset-0 rounded-2xl pointer-events-none"
        style={{
          background:
            "radial-gradient(circle at 50% 50%,#f9731615,transparent 70%)",
        }}
      />
    </div>
  );
}

