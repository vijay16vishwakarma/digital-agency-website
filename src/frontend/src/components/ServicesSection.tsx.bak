// ─────────────────────────────────────────────
// Sub-item Icon (tiny animated)
// ─────────────────────────────────────────────

function SubIcon({ color, index }: { color: string; index: number }) {
  const icons = ["◆", "▸", "●", "✦", "⬡", "◉", "▲", "✿"];
  return (
    <span
      className="inline-flex items-center justify-center shrink-0"
      style={{
        fontSize: 9,
        color,
        width: 16,
        height: 16,
        animation:
          index % 3 === 0
            ? "sub-icon-spin 4s linear infinite"
            : index % 3 === 1
              ? "sub-icon-pulse 2s ease-in-out infinite"
              : "sub-icon-bounce 1.5s ease-in-out infinite",
      }}
    >
      {icons[index % icons.length]}
    </span>
  );
}

// ─────────────────────────────────────────────
// Detail Panel
// ─────────────────────────────────────────────

function DetailPanel({
  sub,
  category,
  onClose,
}: {
  sub: Subcategory;
  category: ServiceCategory;
  onClose: () => void;
}) {
  const AnimComp = category.AnimComp;
  return (
    <motion.div
      key={sub.name}
      initial={{ opacity: 0, y: -20 }}
      animate={{ opacity: 1, y: 0 }}
      exit={{ opacity: 0, y: -20 }}
      transition={{ type: "spring", stiffness: 260, damping: 24 }}
      className="relative rounded-2xl overflow-hidden"
      style={{
        background: "rgba(13,17,23,0.92)",
        backdropFilter: "blur(20px)",
        border: `1px solid ${category.color}33`,
        boxShadow: `0 0 60px ${category.color}15, inset 0 1px 0 ${category.color}20`,
      }}
      data-ocid="services.panel"
    >
      {/* Top glow bar */}
      <div
        className="h-1 w-full"
        style={{
          background: `linear-gradient(90deg, transparent, ${category.color}, transparent)`,
        }}
      />

      {/* Close */}
      <button
        type="button"
        onClick={onClose}
        className="absolute top-4 right-4 z-10 rounded-full flex items-center justify-center transition-all hover:scale-110 hover:rotate-90"
        style={{
          width: 32,
          height: 32,
          background: `${category.color}22`,
          border: `1px solid ${category.color}44`,
          color: category.color,
        }}
        data-ocid="services.close_button"
      >
        <X size={16} />
      </button>

      <div className="p-6 md:p-8 grid md:grid-cols-2 gap-8 items-center">
        {/* Illustration */}
        <div
          className="rounded-xl flex items-center justify-center"
          style={{
            height: 240,
            background: `${category.color}08`,
            border: `1px solid ${category.color}20`,
          }}
        >
          <AnimComp />
        </div>

        {/* Content */}
        <div className="space-y-5">
          {/* Category badge */}
          <div
            className="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold"
            style={{
              background: `${category.color}18`,
              border: `1px solid ${category.color}44`,
              color: category.color,
            }}
          >
            <span
              className="w-1.5 h-1.5 rounded-full"
              style={{ background: category.color }}
            />
            {category.title}
          </div>

          <h3
            className="text-2xl md:text-3xl font-bold leading-tight"
            style={{
              background: `linear-gradient(135deg, ${category.color}, #fff)`,
              WebkitBackgroundClip: "text",
              WebkitTextFillColor: "transparent",
            }}
          >
            {sub.name}
          </h3>

          <p className="text-sm leading-relaxed" style={{ color: "#94a3b8" }}>
            {sub.description}
          </p>

          {/* Benefits */}
          <div className="grid grid-cols-2 gap-2">
            {sub.benefits.map((b, i) => (
              <motion.div
                key={b}
                initial={{ opacity: 0, x: -10 }}
                animate={{ opacity: 1, x: 0 }}
                transition={{ delay: 0.15 + i * 0.08 }}
                className="flex items-center gap-2 rounded-lg px-3 py-2"
                style={{
                  background: `${category.color}10`,
                  border: `1px solid ${category.color}25`,
                }}
              >
                <CheckCircle2
                  size={14}
                  style={{ color: category.color, flexShrink: 0 }}
                />
                <span className="text-xs font-medium text-foreground">{b}</span>
              </motion.div>
            ))}
          </div>

          {/* CTA */}
          <button
            type="button"
            onClick={() => {
              onClose();
              document
                .getElementById("contact")
                ?.scrollIntoView({ behavior: "smooth" });
            }}
            className="inline-flex items-center gap-2 rounded-xl px-6 py-3 font-semibold text-sm transition-all hover:scale-105 hover:shadow-lg"
            style={{
              background: `linear-gradient(135deg, ${category.color}cc, ${category.color}88)`,
              color: "#000",
              boxShadow: `0 0 20px ${category.color}40`,
            }}
            data-ocid="services.primary_button"
          >
            <ExternalLink size={15} />
            Get a Free Quote
          </button>
        </div>
      </div>
    </motion.div>
  );
}

// ─────────────────────────────────────────────
// Main Component
// ─────────────────────────────────────────────

export default function ServicesSection() {
  const ref = useRef(null);
  const inView = useInView(ref, { once: true, margin: "-60px" });
  const [activeCategory, setActiveCategory] = useState<string | null>(null);
  const [activeSub, setActiveSub] = useState<Subcategory | null>(null);
  const panelRef = useRef<HTMLDivElement>(null);

  const activeCat = SERVICES.find((s) => s.id === activeCategory) ?? null;

  function handleSubClick(cat: ServiceCategory, sub: Subcategory) {
    if (activeSub?.name === sub.name) {
      setActiveSub(null);
      setActiveCategory(null);
    } else {
      setActiveCategory(cat.id);
      setActiveSub(sub);
      setTimeout(
        () =>
          panelRef.current?.scrollIntoView({
            behavior: "smooth",
            block: "nearest",
          }),
        120,
      );
    }
  }

  function handleClose() {
    setActiveSub(null);
    setActiveCategory(null);
  }

  return (
    <section
      id="services"
      className="py-24 md:py-32 relative overflow-hidden"
      style={{
        background: "linear-gradient(180deg, #060b10 0%, #0a1118 100%)",
      }}
    >
      <style>{`
        @keyframes sub-icon-spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
        @keyframes sub-icon-pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }
        @keyframes sub-icon-bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-3px)} }
        @keyframes conic-spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
        @keyframes particle-rise { 0%{transform:translateY(0);opacity:0.6} 100%{transform:translateY(-100vh);opacity:0} }
        @keyframes underline-expand { from{transform:scaleX(0)} to{transform:scaleX(1)} }
      `}</style>

      {/* Background mesh */}
      <div
        className="absolute inset-0 pointer-events-none"
        style={{
          background:
            "radial-gradient(ellipse 80% 60% at 50% 0%, oklch(0.25 0.05 198 / 0.4), transparent 70%)",
        }}
      />
      <div
        className="absolute inset-0 pointer-events-none opacity-[0.04]"
        style={{
          backgroundImage:
            "repeating-linear-gradient(0deg,#00d4ff 0px,#00d4ff 1px,transparent 1px,transparent 60px),repeating-linear-gradient(90deg,#00d4ff 0px,#00d4ff 1px,transparent 1px,transparent 60px)",
        }}
      />

      <div className="container mx-auto px-4 md:px-8 relative z-10">
        {/* Header */}
        <div ref={ref} className="text-center mb-16">
          <div
            className="inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase mb-4"
            style={{ color: "#00d4ff" }}
          >
            <span className="w-8 h-px" style={{ background: "#00d4ff" }} />
            Full-Service Digital Solutions • ROI-Focused
            <span className="w-8 h-px" style={{ background: "#00d4ff" }} />
          </div>

          <motion.h2
            initial={{ opacity: 0, filter: "blur(16px)", y: 20 }}
            animate={inView ? { opacity: 1, filter: "blur(0px)", y: 0 } : {}}
            transition={{ duration: 0.9 }}
            className="text-4xl md:text-5xl lg:text-6xl font-bold"
            style={{ fontFamily: "var(--font-display, inherit)" }}
          >
            Everything You Need to{" "}
            <span
              style={{
                background: "linear-gradient(90deg,#00d4ff,#84cc16)",
                WebkitBackgroundClip: "text",
                WebkitTextFillColor: "transparent",
              }}
            >
              Dominate Online
            </span>
          </motion.h2>

          <motion.p
            initial={{ opacity: 0, y: 15 }}
            animate={inView ? { opacity: 1, y: 0 } : {}}
            transition={{ duration: 0.6, delay: 0.4 }}
            className="mt-4 max-w-2xl mx-auto text-base"
            style={{ color: "#94a3b8" }}
          >
            Click any service below to explore it in depth — full descriptions,
            benefits, and how EDMA delivers results that compound.
          </motion.p>
        </div>

        {/* 5-column grid */}
        <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-6">
          {SERVICES.map((cat, ci) => (
            <motion.div
              key={cat.id}
              initial={{ opacity: 0, y: 30 }}
              animate={inView ? { opacity: 1, y: 0 } : {}}
              transition={{
                type: "spring",
                stiffness: 220,
                damping: 22,
                delay: 0.1 * ci,
              }}
              className="rounded-xl p-4 transition-all duration-300 cursor-pointer relative overflow-hidden"
              style={{
                background:
                  activeCategory === cat.id
                    ? `${cat.color}12`
                    : "rgba(255,255,255,0.03)",
                border: `1px solid ${activeCategory === cat.id ? `${cat.color}55` : "rgba(255,255,255,0.07)"}`,
                boxShadow:
                  activeCategory === cat.id
                    ? `0 0 30px ${cat.color}20`
                    : "none",
              }}
              data-ocid="services.tab"
            >
              {/* Category header */}
              <div className="mb-3">
                <h3
                  className="text-base font-bold leading-tight mb-2"
                  style={{
                    background: `linear-gradient(135deg, ${cat.color}, #fff)`,
                    WebkitBackgroundClip: "text",
                    WebkitTextFillColor: "transparent",
                  }}
                >
                  {cat.title}
                </h3>
                {/* Animated underline */}
                <motion.div
                  initial={{ scaleX: 0 }}
                  animate={inView ? { scaleX: 1 } : {}}
                  transition={{
                    duration: 0.7,
                    delay: 0.2 + ci * 0.12,
                    ease: "easeOut",
                  }}
                  className="h-0.5 rounded-full"
                  style={{
                    background: `linear-gradient(90deg, ${cat.color}, transparent)`,
                    transformOrigin: "left",
                  }}
                />
              </div>

              {/* Subcategory list */}
              <ul className="space-y-1.5">
                {cat.subcategories.map((sub, si) => (
                  <li key={sub.name}>
                    <button
                      type="button"
                      onClick={() => handleSubClick(cat, sub)}
                      className="w-full text-left flex items-start gap-1.5 rounded-lg px-2 py-1.5 transition-all duration-200 group/sub"
                      style={{
                        background:
                          activeSub?.name === sub.name
                            ? `${cat.color}20`
                            : "transparent",
                        borderLeft:
                          activeSub?.name === sub.name
                            ? `2px solid ${cat.color}`
                            : "2px solid transparent",
                      }}
                      data-ocid="services.button"
                    >
                      <SubIcon color={cat.color} index={si} />
                      <span
                        className="text-xs leading-tight transition-colors duration-200"
                        style={{
                          color:
                            activeSub?.name === sub.name ? "#fff" : "#94a3b8",
                          fontWeight: activeSub?.name === sub.name ? 600 : 400,
                        }}
                      >
                        {sub.name}
                      </span>
                    </button>
                  </li>
                ))}
              </ul>

              {/* Corner glow */}
              {activeCategory === cat.id && (
                <div
                  className="absolute top-0 right-0 w-16 h-16 pointer-events-none"
                  style={{
                    background: `radial-gradient(circle at top right,${cat.color}30,transparent 70%)`,
                  }}
                />
              )}
            </motion.div>
          ))}
        </div>

        {/* Detail panel */}
        <div ref={panelRef}>
          <AnimatePresence mode="wait">
            {activeSub && activeCat && (
              <DetailPanel
                key={activeSub.name}
                sub={activeSub}
                category={activeCat}
                onClose={handleClose}
              />
            )}
          </AnimatePresence>
        </div>

        {/* Bottom CTA strip */}
        {!activeSub && (
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            animate={inView ? { opacity: 1, y: 0 } : {}}
            transition={{ delay: 0.8 }}
            className="mt-12 text-center"
          >
            <p className="text-sm mb-4" style={{ color: "#64748b" }}>
              Not sure which service fits your goal?
            </p>
            <a
              href="#contact"
              className="inline-flex items-center gap-2 rounded-xl px-8 py-3 font-semibold text-sm transition-all hover:scale-105"
              style={{
                background: "linear-gradient(135deg,#00d4ffcc,#84cc16cc)",
                color: "#000",
                boxShadow: "0 0 30px #00d4ff30",
              }}
              data-ocid="services.primary_button"
            >
              Book a Free Strategy Call
            </a>
          </motion.div>
        )}
      </div>
    </section>
  );
}
